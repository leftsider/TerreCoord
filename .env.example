# Environment Configuration
# Copy this file to .env and fill in your actual values

# Server Configuration
PORT=3000
NODE_ENV=development

# Google Calendar API (from Google Cloud Console)
# Get these from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_client_id_here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:3000/oauth2callback

# Email Configuration (for notifications)
# Using Gmail: Enable "App Passwords" in your Google Account settings
# Or use another SMTP service like SendGrid, Mailgun, etc.
EMAIL_SERVICE=gmail
EMAIL_USER=your-app-email@gmail.com
EMAIL_PASSWORD=your-app-password-here
EMAIL_FROM_NAME=BryandB Property Coordinator

# Application Configuration
APP_NAME=BryandB
APP_URL=http://localhost:3000
OWNER_EMAIL=owner@example.com

# Security (optional but recommended for production)
SESSION_SECRET=generate-a-random-string-here
OWNER_DASHBOARD_PASSWORD=choose-a-secure-password

# Feature Flags
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_PDF_GENERATION=true
ENABLE_CUSTOMS_DOCS=true